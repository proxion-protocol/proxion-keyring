# Auto-generated by Proxion Fleet Security V6
# Base OS: Debian Bookworm Slim
FROM {{ upstream_image }} AS upstream

FROM debian:bookworm-slim

LABEL security.policy="ZERO-TRUST FORGE (V6)"
LABEL proxion.original_image="{{ upstream_image }}"

# 1. Install critical security patches
RUN apt-get update && \
    apt-get upgrade -y && \
    apt-get install -y --no-install-recommends \
    ca-certificates \
    openssl \
    {{ extra_packages | default('') }} && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# 2. Extract Binary and assets from upstream
{% if binary_path %}
COPY --from=upstream {{ binary_path }} {{ binary_path }}
{% endif %}
{% for extra_copy in extra_copies %}
COPY --from=upstream {{ extra_copy.src }} {{ extra_copy.dest }}
{% endfor %}

# 3. Network Configuration
{% for port in exposed_ports %}
EXPOSE {{ port }}
{% endfor %}

WORKDIR {{ workdir | default('/') }}

# 4. Standard Execution
{% if entrypoint %}
ENTRYPOINT {{ entrypoint }}
{% endif %}
{% if cmd %}
CMD {{ cmd }}
{% endif %}
